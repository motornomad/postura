# POSTURA Configuration
# Copy this to .env and fill in your values

# Neo4j
POSTURA_NEO4J_URI=bolt://localhost:7687
POSTURA_NEO4J_USER=neo4j
POSTURA_NEO4J_PASSWORD=postura_dev

# Redis
POSTURA_REDIS_URL=redis://localhost:6379/0

# GitHub Webhook
POSTURA_GITHUB_WEBHOOK_SECRET=
POSTURA_GITHUB_TOKEN=

# LLM Provider
# Options: anthropic | openai | openai_compatible
POSTURA_LLM_PROVIDER=anthropic
POSTURA_LLM_MODEL=claude-sonnet-4-20250514
POSTURA_LLM_API_KEY=

# Local LLM (set LLM_PROVIDER=openai_compatible and point at your local server)
# Ollama:    POSTURA_LLM_BASE_URL=http://localhost:11434/v1  MODEL=llama3.2 or qwen2.5-coder
# vLLM:      POSTURA_LLM_BASE_URL=http://localhost:8000/v1   MODEL=<your loaded model>
# LM Studio: POSTURA_LLM_BASE_URL=http://localhost:1234/v1   MODEL=<your loaded model>
POSTURA_LLM_BASE_URL=

# Vector Store
POSTURA_VECTOR_STORE=chromadb
POSTURA_EMBEDDING_MODEL=BAAI/bge-m3

# Celery
POSTURA_CELERY_BROKER_URL=redis://localhost:6379/0
POSTURA_CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Logging
POSTURA_LOG_LEVEL=INFO
