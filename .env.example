# POSTURA Configuration
# Copy this to .env and fill in your values

# Neo4j
POSTURA_NEO4J_URI=bolt://localhost:7687
POSTURA_NEO4J_USER=neo4j
POSTURA_NEO4J_PASSWORD=postura_dev

# Redis
POSTURA_REDIS_URL=redis://localhost:6379/0

# GitHub Webhook
POSTURA_GITHUB_WEBHOOK_SECRET=
POSTURA_GITHUB_TOKEN=

# LLM Provider
POSTURA_LLM_PROVIDER=anthropic
POSTURA_LLM_MODEL=claude-sonnet-4-20250514
POSTURA_LLM_API_KEY=

# Vector Store
POSTURA_VECTOR_STORE=chromadb
POSTURA_EMBEDDING_MODEL=BAAI/bge-m3

# Celery
POSTURA_CELERY_BROKER_URL=redis://localhost:6379/0
POSTURA_CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Logging
POSTURA_LOG_LEVEL=INFO
